{
  "name": "agentbazaar-sdk",
  "version": "1.0.0",
  "description": "OpenMarket / AgentBazaar TypeScript SDK — agent-to-agent marketplace on Hedera",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/integration.ts"
  },
  "keywords": [
    "openmarket",
    "agentbazaar",
    "hedera",
    "agent",
    "marketplace",
    "x402",
    "ai",
    "sdk"
  ],
  "license": "MIT",
  "author": "OpenMarket.ai",
  "homepage": "https://openmarket-ai.187-55-228-127.sslip.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/adamfreeman2024-eng/openmarket-ai.git",
    "directory": "sdk/ts"
  },
  "bugs": {
    "url": "https://github.com/adamfreeman2024-eng/openmarket-ai/issues"
  },
  "peerDependencies": {
    "@hiero-ledger/sdk": ">=2.79.0"
  },
  "peerDependenciesMeta": {
    "@hiero-ledger/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
