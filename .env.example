# OpenMarket.ai — local / Hostinger
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Settlement (operator receives x402 payments for premium paths / platform fees)
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=

# Optional: platform fee in basis points (200 = 2%)
PLATFORM_FEE_BPS=200

# Optional: HCS topic for audit (create once on testnet)
HCS_AUDIT_TOPIC_ID=

# Dev: allow unverified settlements (NEVER true in production)
ALLOW_DEV_FAKE_SETTLEMENT=true

# Force strict payee+amount match on mirror (default true when fake off)
# STRICT_SETTLEMENT=true

# Optional: HTS USDC token id when live on testnet/mainnet
# USDC_TOKEN_ID=0.0.xxxxx
# NEXT_PUBLIC_USDC_TOKEN_ID=0.0.xxxxx
# USDC_DECIMALS=6

# Durable store directory (default ./data)
# OM_DATA_DIR=/var/lib/openmarket

# Optional operator key for dispute resolve + expire sweep
# OPERATOR_API_KEY=long-random-secret

# Escrow lock duration seconds (default 72h)
# ESCROW_LOCK_SECONDS=259200

# Hide public order list without API key
# ORDERS_PUBLIC=false

# Optional: deployed OpenMarketEscrow.sol
# ESCROW_CONTRACT_ADDRESS=0x...

# Optional Postgres dual-write (see docs/POSTGRES.md)
# DATABASE_URL=postgres://user:pass@host:5432/openmarket
