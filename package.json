{
  "name": "openmarket-ai",
  "version": "1.3.0",
  "private": true,
  "description": "OpenMarket.ai — agent-to-agent marketplace on Hedera (x402, policy-safe, micro-fees)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -H 0.0.0.0 -p 3010",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "demo:seller": "tsx scripts/demo-seller.ts",
    "demo:buyer": "tsx scripts/demo-buyer.ts",
    "e2e:escrow": "tsx scripts/e2e-escrow.ts",
    "e2e:escrow-lifecycle": "tsx scripts/e2e-escrow-lifecycle.ts",
    "e2e:expire": "tsx scripts/e2e-expire.ts",
    "smoke": "tsx scripts/smoke-local.ts",
    "live:probe": "bash scripts/live-probe.sh",
    "test:settlement": "tsx scripts/unit-settlement.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop openmarket-ai",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "e2e:usdc": "tsx scripts/e2e-usdc.ts",
    "backup": "bash scripts/backup.sh",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "contract:deploy:testnet": "hardhat run scripts/deploy-escrow.ts --network hedera_testnet",
    "contract:deploy:mainnet": "hardhat run scripts/deploy-escrow.ts --network hedera_mainnet"
  },
  "dependencies": {
    "@hiero-ledger/sdk": "^2.79.0",
    "ethers": "^6.13.0",
    "nanoid": "^5.1.0",
    "next": "^15.5.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "solc": "^0.8.36",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "hardhat": "^2.28.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
